---
export const prerender = true;

import Breadcrumbs from '@components/ui/Breadcrumbs.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import FeatureMatrix from '@components/widgets/FeatureMatrix.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { featureChecklist } from '@data/creation';
import { webPageSchema } from '@lib/seo';

const title = 'Astro 6 feature coverage';
const description =
  'The technical checklist for a state-of-the-art Astro 6 template.';
const url = new URL(Astro.url.pathname, Astro.site).toString();
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={webPageSchema({ title, description, url })}
>
  <section class="bg-slate-100 py-16 dark:bg-zinc-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Features' }]} />
      <div class="mt-8">
        <SectionHeader
          eyebrow="Checklist"
          title={title}
          description={description}
        />
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {
          featureChecklist.map((item) => (
            <div class="rounded-md border border-slate-950/10 bg-white p-6 dark:border-white/10 dark:bg-zinc-950">
              <h2 class="font-serif text-xl font-bold text-slate-950 dark:text-white">
                {item}
              </h2>
              <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">
                This capability is implemented in repository code and referenced
                in the documentation.
              </p>
            </div>
          ))
        }
      </div>
      <div class="mt-10">
        <FeatureMatrix />
      </div>
    </div>
  </section>
</BaseLayout>
