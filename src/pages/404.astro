---
export const prerender = true;

import Button from '@components/ui/Button.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The requested page could not be found."
  noindex
>
  <section
    class="grid min-h-[60vh] place-items-center bg-slate-100 px-4 py-20 text-center dark:bg-zinc-900"
  >
    <div class="max-w-xl">
      <p class="text-sm font-bold uppercase text-cedar dark:text-teal-300">
        404
      </p>
      <h1
        class="mt-4 font-serif text-5xl font-bold text-slate-950 dark:text-white"
      >
        This path has not been formed.
      </h1>
      <p class="mt-5 text-slate-600 dark:text-slate-300">
        Return to the template surface or use the navigation above.
      </p>
      <div class="mt-8">
        <Button href="/">Go home</Button>
      </div>
    </div>
  </section>
</BaseLayout>
