---
export const prerender = true;

import Breadcrumbs from '@components/ui/Breadcrumbs.astro';
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Architecture';
const description = 'Rendering, boundaries, and dynamic feature architecture.';
---

<BaseLayout title={title} description={description}>
  <section class="bg-white py-16 dark:bg-zinc-950">
    <div class="prose mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs
        items={[{ label: 'Docs', href: '/docs' }, { label: title }]}
      />
      <h1>{title}</h1>
      <h2>Rendering model</h2>
      <p>
        The repository uses server output so SSR features stay available. Static
        pages opt into prerendering route by route.
      </p>
      <h2>Boundaries</h2>
      <p>
        Content lives in `src/content`, structured data in `src/data`,
        components in `src/components`, route ownership in `src/pages`, and
        maintenance notes in `docs`.
      </p>
      <h2>Dynamic routes</h2>
      <p>
        `/dynamic` demonstrates middleware, request context, Sessions, and
        Server Islands. `/dynamic/live` demonstrates Live Content Collections.
      </p>
    </div>
  </section>
</BaseLayout>
