---
export const prerender = true;

import Breadcrumbs from '@components/ui/Breadcrumbs.astro';
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Updating';
const description = 'How to keep the repository current through GitHub.';
---

<BaseLayout title={title} description={description}>
  <section class="bg-white py-16 dark:bg-zinc-950">
    <div class="prose mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs
        items={[{ label: 'Docs', href: '/docs' }, { label: title }]}
      />
      <h1>{title}</h1>
      <h2>Routine flow</h2>
      <p>
        Run `npm run upgrade`, then `npm install`, `npm run check`, and `npm run
        build`.
      </p>
      <h2>Pull requests</h2>
      <p>
        Dependabot groups Astro and Tailwind upgrades so framework changes can
        be reviewed cleanly.
      </p>
      <h2>Inspection points</h2>
      <p>
        After an upgrade, inspect `astro.config.ts`, content collections, live
        collections, actions, SEO head, and Docker runtime requirements.
      </p>
    </div>
  </section>
</BaseLayout>
