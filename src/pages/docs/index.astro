---
export const prerender = true;

import Breadcrumbs from '@components/ui/Breadcrumbs.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import FeatureMatrix from '@components/widgets/FeatureMatrix.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { webPageSchema } from '@lib/seo';

const title = 'Implementation documentation';
const description =
  'How to update, extend, deploy, and keep Astro Genesis aligned with Astro 6.';
const url = new URL(Astro.url.pathname, Astro.site).toString();
const docs = [
  {
    title: 'Astro 6 checklist',
    href: '/docs/astro-6-checklist',
    summary: 'Feature adoption decisions and source links.',
  },
  {
    title: 'Architecture',
    href: '/docs/architecture',
    summary: 'Project boundaries, routing, and rendering model.',
  },
  {
    title: 'Content model',
    href: '/docs/content-model',
    summary: 'How demo content is separated from reusable template code.',
  },
  {
    title: 'Deployment',
    href: '/docs/deployment',
    summary: 'Docker, Node adapter, environment variables, and CI.',
  },
  {
    title: 'Updating',
    href: '/docs/updating',
    summary: 'How to keep the repository current through GitHub.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={webPageSchema({ title, description, url })}
>
  <section class="bg-white py-16 dark:bg-zinc-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Docs' }]} />
      <div class="mt-8">
        <SectionHeader eyebrow="Docs" title={title} description={description} />
      </div>
      <div class="mt-10 grid gap-4 md:grid-cols-2">
        {
          docs.map((doc) => (
            <a
              href={doc.href}
              class="rounded-md border border-slate-950/10 bg-slate-50 p-6 no-underline hover:bg-white hover:shadow-lg dark:border-white/10 dark:bg-zinc-900 dark:hover:bg-zinc-950"
            >
              <h2 class="font-serif text-2xl font-bold text-slate-950 dark:text-white">
                {doc.title}
              </h2>
              <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">
                {doc.summary}
              </p>
            </a>
          ))
        }
      </div>
      <div class="mt-10">
        <FeatureMatrix />
      </div>
    </div>
  </section>
</BaseLayout>
