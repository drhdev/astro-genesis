---
export const prerender = true;

import Breadcrumbs from '@components/ui/Breadcrumbs.astro';
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Imprint';
const description = 'A placeholder imprint page for production templates.';
---

<BaseLayout title={title} description={description} noindex>
  <section class="bg-white py-16 dark:bg-zinc-950">
    <div class="prose mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Legal' }, { label: 'Imprint' }]} />
      <h1>{title}</h1>
      <p>
        Add your organization, responsible contact, address, tax, and legal
        disclosure details here before deployment.
      </p>
    </div>
  </section>
</BaseLayout>
