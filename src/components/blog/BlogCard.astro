---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
---

<article
  class="overflow-hidden rounded-md border border-slate-950/10 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg dark:border-white/10 dark:bg-zinc-900"
>
  <a href={`/blog/${post.id}`} class="block no-underline">
    <img
      src={post.data.image.src}
      alt={post.data.image.alt}
      class="aspect-[16/9] w-full object-cover"
      loading="lazy"
    />
    <div class="p-5">
      <div class="flex flex-wrap gap-2">
        {
          post.data.tags
            .slice(0, 2)
            .map((tag) => (
              <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-bold uppercase text-slate-600 dark:bg-white/10 dark:text-slate-300">
                {tag}
              </span>
            ))
        }
      </div>
      <h2
        class="mt-4 font-serif text-2xl font-bold leading-tight text-slate-950 dark:text-white"
      >
        {post.data.title}
      </h2>
      <p
        class="mt-3 line-clamp-3 text-sm leading-6 text-slate-600 dark:text-slate-300"
      >
        {post.data.description}
      </p>
      <time
        class="mt-5 block text-xs font-semibold uppercase text-slate-500 dark:text-slate-400"
        datetime={post.data.pubDate.toISOString()}
      >
        {post.data.pubDate.toLocaleDateString('en', { dateStyle: 'medium' })}
      </time>
    </div>
  </a>
</article>
