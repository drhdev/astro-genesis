---
const now = new Date();
const requestId = Astro.locals.requestId;
---

<aside
  class="rounded-md border border-teal-500/30 bg-teal-50 p-5 text-teal-950 dark:bg-teal-950/30 dark:text-teal-50"
>
  <p class="text-xs font-bold uppercase">Server island</p>
  <h2 class="mt-2 font-serif text-2xl font-bold">
    Rendered after the page shell
  </h2>
  <p class="mt-3 text-sm leading-6">
    Server time: <time datetime={now.toISOString()}
      >{
        now.toLocaleString('en', { dateStyle: 'medium', timeStyle: 'medium' })
      }</time
    >
  </p>
  <p class="mt-2 text-xs opacity-80">Request ID: {requestId}</p>
</aside>
