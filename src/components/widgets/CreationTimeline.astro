---
import SectionHeader from '@components/ui/SectionHeader.astro';
import { creationDays } from '@data/creation';
---

<section class="bg-slate-100 py-20 dark:bg-zinc-900">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeader
      eyebrow="Content model"
      title="Genesis as structured demo content"
      description="Each creation day is represented as content data and routed into pages, widgets, live collections, and dynamic endpoints."
    />
    <div class="mt-12 grid gap-4 lg:grid-cols-7">
      {
        creationDays.map((item) => (
          <a
            href={item.href}
            class="rounded-md border border-slate-950/10 bg-white p-5 no-underline transition hover:-translate-y-1 hover:shadow-lg dark:border-white/10 dark:bg-zinc-950"
          >
            <p class="text-sm font-black uppercase text-gold dark:text-amber-300">
              Day {item.day}
            </p>
            <h3 class="mt-3 font-serif text-xl font-bold leading-tight text-slate-950 dark:text-white">
              {item.title}
            </h3>
            <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">
              {item.summary}
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>
