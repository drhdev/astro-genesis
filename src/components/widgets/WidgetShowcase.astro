---
import SectionHeader from '@components/ui/SectionHeader.astro';
import { faqs, widgetGroups } from '@data/widgets';
---

<section class="bg-white py-20 dark:bg-zinc-950">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeader
      eyebrow="Widgets"
      title="A complete starter surface"
      description="Common website modules are included as simple Astro components, with just enough JavaScript for menus, tabs, accordions, and theme control."
    />

    <div class="mt-12 grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div
        class="rounded-md border border-slate-950/10 bg-slate-50 p-2 dark:border-white/10 dark:bg-white/5"
      >
        <div
          role="tablist"
          aria-label="Widget groups"
          class="grid grid-cols-3 gap-2"
        >
          {
            widgetGroups.map((group, index) => (
              <button
                type="button"
                role="tab"
                aria-selected={index === 0 ? 'true' : 'false'}
                aria-controls={`panel-${index}`}
                id={`tab-${index}`}
                class="rounded-md px-3 py-3 text-sm font-bold text-slate-700 data-[active=true]:bg-white data-[active=true]:text-cedar dark:text-slate-200 dark:data-[active=true]:bg-zinc-950"
                data-tabs-tab
                data-active={index === 0 ? 'true' : 'false'}
              >
                {group.title}
              </button>
            ))
          }
        </div>
        {
          widgetGroups.map((group, index) => (
            <div
              role="tabpanel"
              id={`panel-${index}`}
              aria-labelledby={`tab-${index}`}
              class="p-6"
              data-tabs-panel
              hidden={index !== 0}
            >
              <h3 class="font-serif text-2xl font-bold text-slate-950 dark:text-white">
                {group.title}
              </h3>
              <div class="mt-5 grid gap-3 sm:grid-cols-2">
                {group.items.map((item) => (
                  <div class="rounded-md bg-white p-4 text-sm font-semibold text-slate-700 shadow-sm dark:bg-zinc-950 dark:text-slate-200">
                    {item}
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>

      <div class="space-y-3">
        {
          faqs.map((faq, index) => (
            <details
              class="rounded-md border border-slate-950/10 bg-white p-5 dark:border-white/10 dark:bg-zinc-900"
              open={index === 0}
            >
              <summary class="cursor-pointer font-serif text-xl font-bold text-slate-950 dark:text-white">
                {faq.question}
              </summary>
              <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">
                {faq.answer}
              </p>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-tabs-tab]').forEach((tab, index) => {
    tab.addEventListener('click', () => {
      const root = tab.closest('section');
      root?.querySelectorAll('[data-tabs-tab]').forEach((item, itemIndex) => {
        const active = itemIndex === index;
        item.setAttribute('aria-selected', String(active));
        item.setAttribute('data-active', String(active));
      });
      root
        ?.querySelectorAll('[data-tabs-panel]')
        .forEach((panel, panelIndex) => {
          (panel as HTMLElement).hidden = panelIndex !== index;
        });
    });
  });
</script>
