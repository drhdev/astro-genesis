---
import { footerNavigation } from '@data/navigation';
import { siteConfig, socialLinks } from '@data/site';
---

<footer
  class="border-t border-slate-950/10 bg-white dark:border-white/10 dark:bg-zinc-950"
>
  <div
    class="mx-auto grid max-w-7xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[1.4fr_2fr] lg:px-8"
  >
    <div>
      <a
        href="/"
        class="flex items-center gap-3 font-serif text-xl font-bold text-slate-950 no-underline dark:text-white"
      >
        <span
          class="grid size-9 place-items-center rounded-md bg-cedar text-sm font-black text-white"
          >AG</span
        >
        <span>{siteConfig.name}</span>
      </a>
      <p
        class="mt-4 max-w-md text-sm leading-6 text-slate-600 dark:text-slate-300"
      >
        {siteConfig.description}
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              class="rounded-md border border-slate-950/10 px-3 py-2 text-sm font-semibold text-slate-700 no-underline hover:bg-slate-100 dark:border-white/15 dark:text-slate-200 dark:hover:bg-white/10"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
    <div class="grid gap-8 sm:grid-cols-3">
      {
        footerNavigation.map((group) => (
          <div>
            <h2 class="text-sm font-bold uppercase text-slate-950 dark:text-white">
              {group.title}
            </h2>
            <ul class="mt-4 grid gap-3">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-slate-600 no-underline hover:text-cedar dark:text-slate-300 dark:hover:text-teal-300"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
  <div
    class="border-t border-slate-950/10 px-4 py-5 text-center text-sm text-slate-500 dark:border-white/10 dark:text-slate-400"
  >
    &copy; {new Date().getFullYear()}{' '}
    {siteConfig.name}. Built with Astro 6.
  </div>
</footer>
