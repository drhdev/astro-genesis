---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="text-sm text-slate-500 dark:text-slate-400" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-2">
    <li>
      <a href="/" class="no-underline hover:text-cedar dark:hover:text-teal-300"
        >Home</a
      >
    </li>
    {
      items.map((item) => (
        <>
          <li aria-hidden="true">/</li>
          <li>
            {item.href ? (
              <a
                href={item.href}
                class="no-underline hover:text-cedar dark:hover:text-teal-300"
              >
                {item.label}
              </a>
            ) : (
              <span class="text-slate-800 dark:text-slate-200">
                {item.label}
              </span>
            )}
          </li>
        </>
      ))
    }
  </ol>
</nav>
