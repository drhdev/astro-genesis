---
interface Props {
  title: string;
  tone?: 'teal' | 'gold' | 'indigo';
}

const { title, tone = 'teal' } = Astro.props;
const tones = {
  teal: 'border-teal-500/30 bg-teal-50 text-teal-950 dark:bg-teal-950/40 dark:text-teal-50',
  gold: 'border-amber-500/30 bg-amber-50 text-amber-950 dark:bg-amber-950/30 dark:text-amber-50',
  indigo:
    'border-indigo-500/30 bg-indigo-50 text-indigo-950 dark:bg-indigo-950/40 dark:text-indigo-50',
};
---

<aside class:list={['my-8 rounded-md border p-5', tones[tone]]}>
  <h3 class="m-0 text-base font-bold">{title}</h3>
  <div class="mt-2 text-sm leading-7">
    <slot />
  </div>
</aside>
