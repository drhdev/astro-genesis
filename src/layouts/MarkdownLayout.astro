---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
}

const {
  title,
  description,
  image,
  pubDate,
  updatedDate,
  tags = [],
} = Astro.props;

const layoutProps = {
  title,
  description,
  type: 'article' as const,
  ...(image ? { image } : {}),
};
---

<BaseLayout {...layoutProps}>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-10">
      <p class="text-sm font-bold uppercase text-cedar dark:text-teal-300">
        Genesis journal
      </p>
      <h1
        class="mt-4 font-serif text-4xl font-bold leading-tight text-slate-950 sm:text-5xl dark:text-white"
      >
        {title}
      </h1>
      <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">
        {description}
      </p>
      <div
        class="mt-6 flex flex-wrap items-center gap-3 text-sm text-slate-500 dark:text-slate-400"
      >
        {
          pubDate && (
            <time datetime={pubDate.toISOString()}>
              {pubDate.toLocaleDateString('en', { dateStyle: 'long' })}
            </time>
          )
        }
        {
          updatedDate && (
            <span>
              Updated{' '}
              {updatedDate.toLocaleDateString('en', { dateStyle: 'medium' })}
            </span>
          )
        }
      </div>
      {
        tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold uppercase text-slate-700 no-underline dark:bg-white/10 dark:text-slate-200"
              >
                {tag}
              </a>
            ))}
          </div>
        )
      }
    </div>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
